---
import { buttonVariants } from "@/app/components/ui/button";
import RootLayout from "@/layouts/root-layout.astro";
const { user } = Astro.locals;

if (user) return Astro.redirect("/admin");
---

<RootLayout>
  <h1>Welcome to the Contact Me API</h1>
  <p>This is the home page of the Contact Me API project.</p>

  <a class={buttonVariants({ size: "lg" })} href="/admin">Login</a>
</RootLayout>
