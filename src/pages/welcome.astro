---
import LoginButton from "@/app/components/login-button";
import RootLayout from "@/layouts/root-layout.astro";

const { user } = Astro.locals;
if (user) {
  return Astro.redirect("/");
}
---

<RootLayout>
  <main class="flex flex-col items-center h-screen">
    <div class="flex-1"></div>
    <div class="max-w-md w-full px-4">
      <section class="flex flex-col items-center gap-2 mb-10 text-center">
        <h1 class="text-3xl sm:text-5xl font-bold tracking-tight">
          Contactulator
        </h1>
        <p class="text-sm text-muted-foreground text-pretty">
          The best way to keep on top of your user's needs and wants
        </p>
      </section>
      <div class="w-full grid sm:grid-cols-2 gap-3">
        <LoginButton provider="google" />
        <LoginButton provider="github" />
      </div>
    </div>
    <div class="flex-2"></div>
  </main>
</RootLayout>
